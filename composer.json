{
    "name": "anilcancakir/laravel-agent-mcp",
    "description": "Secure MCP server package for Laravel: DB schema/query, logs, and allowlisted artisan for authenticated LLM agents.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^11.0||^12.0",
        "laravel/mcp": ">=0.7 <0.8",
        "laravel/sanctum": "^4.0",
        "phpmyadmin/sql-parser": "^5.10",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0||^10.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18"
    },
    "autoload": {
        "psr-4": {
            "Anilcancakir\\LaravelAgentMcp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Anilcancakir\\LaravelAgentMcp\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Anilcancakir\\LaravelAgentMcp\\AgentMcpServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=512M",
        "format": "vendor/bin/pint"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
