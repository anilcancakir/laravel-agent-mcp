{
    // If you only occasionally need these tools, you can skip registering a server here
    // entirely and call them from the shell instead:
    //   php artisan agent-mcp:tools
    //   php artisan agent-mcp:call db_schema '{"table":"users"}'
    // Register a server below when you want persistent tool access across an interactive
    // session. See the README "CLI usage" section.
    "mcpServers": {
        // HTTP transport (Streamable HTTP, recommended for remote or production use).
        //
        // Set AGENT_MCP_KEY in your shell profile or .env.local before starting
        // the client. The ${AGENT_MCP_KEY} placeholder is expanded from your
        // environment. Never paste a real key here; use the environment variable.
        "agent-mcp-http": {
            "type": "http",
            "url": "https://your-app.test/agent-mcp",
            "headers": {
                "Authorization": "Bearer ${AGENT_MCP_KEY}"
            }
        },

        // stdio bridge transport (remote bridge, for clients such as Claude Desktop
        // that cannot send custom HTTP headers natively).
        //
        // The bridge spawns a local artisan process that reads JSON-RPC lines from
        // stdin, forwards each request to the remote HTTP endpoint with the Bearer
        // key, and writes the reply to stdout. This replaces the mcp-remote shim
        // for this package.
        //
        // AGENT_MCP_URL: the remote /agent-mcp endpoint (must be HTTPS in production).
        // AGENT_MCP_KEY: the server-admin key configured on the remote server.
        // Both values are operator-set environment variables; they are never written
        // to stdout or logged by the bridge.
        "agent-mcp-stdio": {
            "type": "stdio",
            "command": "php",
            "args": ["artisan", "agent-mcp:stdio"],
            "env": {
                "AGENT_MCP_URL": "https://your-app.test/agent-mcp",
                "AGENT_MCP_KEY": "${AGENT_MCP_KEY}"
            }
        }
    }
}
